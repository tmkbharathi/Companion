<Window x:Class="tmkbCompanion.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:tmkbCompanion"
        xmlns:vm="clr-namespace:tmkbCompanion.MVVM.ViewModel"
        xmlns:view="clr-namespace:tmkbCompanion.MVVM.View"
        mc:Ignorable="d"
        Title="FlowTrack"
        Height="500"
        Width="800"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- View Model → View mappings -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <view:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <view:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfileSetupViewModel}">
            <view:ProfileSetupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WaterReminderViewModel}">
            <view:WaterReminderView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClipboardHistoryViewModel}">
            <view:ClipboardHistoryView/>
        </DataTemplate>

        <!-- Sidebar Navigation RadioButton Style -->
        <Style x:Key="SidebarMenuItem" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Padding" Value="12,0,0,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderThickness="0"
                                SnapsToDevicePixels="true">
                            <Grid>
                                <!-- Left active indicator pill -->
                                <Border x:Name="ActiveIndicator"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Height="24" Width="4"
                                        Background="{DynamicResource AccentBrush}"
                                        CornerRadius="2"
                                        Visibility="Collapsed"/>

                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="IconBlock"
                                               Grid.Column="0"
                                               FontFamily="{StaticResource SegoeMDL2}"
                                               Text="{TemplateBinding Tag}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{TemplateBinding Content}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               ToolTip="{TemplateBinding Content}"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#2a303f"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#33343c"/>
                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="IconBlock" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hamburger button style (three-line menu) -->
        <Style x:Key="HamburgerButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                SnapsToDevicePixels="True">
                            <!-- Draw 3 lines manually so they never depend on fonts -->
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Width="16">
                                <Border Height="2" CornerRadius="1"
                                        Background="{StaticResource TextPrimaryBrush}"
                                        Margin="0,0,0,3"/>
                                <Border Height="2" CornerRadius="1"
                                        Background="{StaticResource TextPrimaryBrush}"
                                        Margin="0,0,0,3"/>
                                <Border Height="2" CornerRadius="1"
                                        Background="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2a303f"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#363d50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer rounded border -->
    <Border Background="{StaticResource BaseBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <!-- Title bar -->
                <RowDefinition Height="32"/>
                <!-- App body -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <!-- Sidebar — width animated in code-behind via x:Name SidebarColumn -->
                <ColumnDefinition x:Name="SidebarColumn" Width="160"/>
                <!-- Content — * always fills remaining space automatically -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════
                 1. TITLE BAR  (spans both columns)
                 ══════════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                    Background="#191b22"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>

                    <!-- Left: hamburger button (no app name / logo) -->
                    <Button x:Name="HamburgerBtn"
                            Style="{StaticResource HamburgerButton}"
                            Command="{Binding ToggleSidebarCommand}"
                            HorizontalAlignment="Left"
                            Margin="8,0,0,0"
                            ToolTip="Toggle sidebar"/>

                    <!-- Right: profile + window controls -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <!-- Profile strip (hidden on Profile Setup page) -->
                        <Border Background="Transparent"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsProfileTitleBarVisible,
                                                     Converter={StaticResource BoolToVis}}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding ShowProfileSetupCommand}"/>
                            </Border.InputBindings>
                            <StackPanel Orientation="Horizontal">
                                <!-- Avatar circle -->
                                <Border Width="20" Height="20"
                                        CornerRadius="10"
                                        ClipToBounds="True"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProfileSetupVM.HasProfilePicture}" Value="True">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <ImageBrush ImageSource="{Binding ProfileSetupVM.ProfilePicturePath,
                                                                                      UpdateSourceTrigger=PropertyChanged}"
                                                                        Stretch="UniformToFill"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <TextBlock FontFamily="{StaticResource SegoeMDL2}"
                                                   Text="&#xF007;" FontSize="11"
                                                   Foreground="#001847"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProfileSetupVM.HasProfilePicture}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- User name -->
                                <TextBlock Text="{Binding UserName}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           FontFamily="{StaticResource AppFont}"/>
                            </StackPanel>
                        </Border>

                        <!-- Minimize -->
                        <Button Style="{StaticResource TitleBarButton}" Click="MinimizeBtn_Click">
                            <TextBlock FontFamily="{StaticResource SegoeMDL2}"
                                       Text="&#xF068;" FontSize="10"/>
                        </Button>
                        <!-- Close (minimizes to tray) -->
                        <Button Style="{StaticResource TitleBarCloseButton}" Click="CloseBtn_Click">
                            <TextBlock FontFamily="{StaticResource SegoeMDL2}"
                                       Text="&#xF00D;" FontSize="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════
                 2. SIDEBAR NAVIGATION
                 ══════════════════════════════════════════ -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="0,16,0,16"
                    ClipToBounds="True">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- App name block in sidebar header -->
                    <StackPanel Grid.Row="0" Margin="16,0,16,20">
                        <TextBlock Text="FlowTrack"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="{Binding AppVersion}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="9"
                                   Opacity="0.6"
                                   FontFamily="{StaticResource AppFont}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <RadioButton Style="{StaticResource SidebarMenuItem}"
                                     IsChecked="True"
                                     Tag="&#xF015;"
                                     Command="{Binding ShowDashboardCommand}"
                                     Content="Dashboard"/>
                        <RadioButton Style="{StaticResource SidebarMenuItem}"
                                     Tag="&#xF043;"
                                     Command="{Binding ShowWaterReminderCommand}"
                                     Content="Water Reminder"/>
                        <RadioButton Style="{StaticResource SidebarMenuItem}"
                                     Tag="&#xF0EA;"
                                     Command="{Binding ShowClipboardCommand}"
                                     Content="Clipboard History"/>
                        <RadioButton Style="{StaticResource SidebarMenuItem}"
                                     Tag="&#xF013;"
                                     Command="{Binding ShowSettingsCommand}"
                                     Content="Settings"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════
                 3. MAIN CONTENT — fills remaining column
                 ══════════════════════════════════════════ -->
            <ContentControl Grid.Row="1" Grid.Column="1"
                            Content="{Binding CurrentView}"/>

            <!-- ══════════════════════════════════════════
                 4. SLIDE-IN TOAST OVERLAY
                 ══════════════════════════════════════════ -->
            <Border Grid.Row="1" Grid.Column="1"
                    Background="#1c2230"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Width="320" MinHeight="80" Height="Auto"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,24,24"
                    Padding="16"
                    Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVis}}"
                    Panel.ZIndex="1000">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#10b981" Opacity="0.1" CornerRadius="16"
                            Width="32" Height="32" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="0"
                               FontFamily="{StaticResource SegoeMDL2}"
                               Text="&#xF058;" FontSize="16"
                               Foreground="#10b981"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ToastTitle}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="Bold"
                                   FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="{Binding ToastMessage}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11" Margin="0,2,0,0"
                                   FontFamily="{StaticResource AppFont}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
