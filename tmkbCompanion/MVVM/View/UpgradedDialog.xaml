<UserControl x:Class="tmkbCompanion.MVVM.View.UpgradedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="360" Width="440"
        Background="Transparent"
        Loaded="Window_Loaded">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Theme/ThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="#151925" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1.5" 
            CornerRadius="20">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="35" ShadowDepth="8" Opacity="0.6"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Row 0: Animated Success checkmark & Confetti ── -->
            <Grid Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Width="300" Height="140">
                <!-- Background glow -->
                <Ellipse Width="100" Height="100" Fill="{DynamicResource AccentBrush}" Opacity="0.1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse.Effect>
                        <BlurEffect Radius="30"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Confetti particles (animated in code-behind / XAML storyboards) -->
                <!-- Confetti 1 -->
                <Rectangle x:Name="confetti1" Opacity="0" Width="8" Height="8" Fill="#FFC107" RadiusX="2" RadiusY="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Rectangle.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform x:Name="c1" X="0" Y="0"/>
                            <RotateTransform x:Name="cr1" Angle="0"/>
                        </TransformGroup>
                    </Rectangle.RenderTransform>
                </Rectangle>
                <!-- Confetti 2 -->
                <Ellipse x:Name="confetti2" Opacity="0" Width="6" Height="6" Fill="#FF5252" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="c2" X="0" Y="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <!-- Confetti 3 -->
                <Rectangle x:Name="confetti3" Opacity="0" Width="6" Height="12" Fill="#4CAF50" RadiusX="1" RadiusY="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Rectangle.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform x:Name="c3" X="0" Y="0"/>
                            <RotateTransform x:Name="cr3" Angle="0"/>
                        </TransformGroup>
                    </Rectangle.RenderTransform>
                </Rectangle>
                <!-- Confetti 4 -->
                <Ellipse x:Name="confetti4" Opacity="0" Width="8" Height="8" Fill="#E040FB" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="c4" X="0" Y="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <!-- Confetti 5 -->
                <Rectangle x:Name="confetti5" Opacity="0" Width="10" Height="6" Fill="#00E676" RadiusX="2" RadiusY="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Rectangle.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform x:Name="c5" X="0" Y="0"/>
                            <RotateTransform x:Name="cr5" Angle="0"/>
                        </TransformGroup>
                    </Rectangle.RenderTransform>
                </Rectangle>

                <!-- Main Success Checkmark Ring -->
                <Grid x:Name="SuccessRing" RenderTransformOrigin="0.5,0.5" Width="70" Height="70" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="0" ScaleY="0"/>
                    </Grid.RenderTransform>
                    
                    <Ellipse Stroke="{DynamicResource AccentBrush}" StrokeThickness="4" Fill="#1c2230">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="{DynamicResource AccentColor}" ShadowDepth="0" BlurRadius="12" Opacity="0.5"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <!-- Vector Checkmark -->
                    <Path Data="M 22 36 L 31 45 L 48 26" 
                          Stroke="{DynamicResource AccentBrush}" 
                          StrokeThickness="5" 
                          StrokeStartLineCap="Round" 
                          StrokeEndLineCap="Round" 
                          StrokeLineJoin="Round"
                          Width="70" Height="70"
                          Stretch="None" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                </Grid>
            </Grid>

            <!-- ── Row 1: Upgrade Text and Badges ── -->
            <StackPanel Grid.Row="1" Margin="0,0,0,20" HorizontalAlignment="Center">
                <TextBlock Text="FlowTrack Upgraded!" 
                           Foreground="{StaticResource TextPrimaryBrush}" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           FontFamily="{StaticResource AppFont}"/>
                
                <TextBlock Text="Your application has been successfully updated." 
                           Foreground="{StaticResource TextMutedBrush}" 
                           FontSize="12" 
                           Margin="0,4,0,16"
                           HorizontalAlignment="Center"
                           FontFamily="{StaticResource AppFont}"/>

                <!-- Version Badges: [vOld] -> [vNew] -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Background="#222837" CornerRadius="8" Padding="12,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <TextBlock x:Name="OldVersionText" Text="v1.1.1" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                    </Border>
                    
                    <!-- Glowing arrow symbol -->
                    <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                               Text="&#xF061;" 
                               FontSize="14" 
                               Foreground="{DynamicResource AccentBrush}" 
                               VerticalAlignment="Center" 
                               Margin="12,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="{DynamicResource AccentColor}" ShadowDepth="0" BlurRadius="8" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <Border CornerRadius="8" Padding="12,6" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                        <Border.Background>
                            <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15"/>
                        </Border.Background>
                        <TextBlock x:Name="NewVersionText" Text="v1.1.2" Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="Bold" FontFamily="{StaticResource AppFont}">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource AccentColor}" ShadowDepth="0" BlurRadius="6" Opacity="0.4"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- ── Row 2: Let's Go Button ── -->
            <Button x:Name="LetsGoButton" Grid.Row="2"
                    Style="{StaticResource FluentButton}"
                    Content="Let's Go!"
                    Click="Close_Click"
                    Width="160" Height="40"
                    HorizontalAlignment="Center"
                    Opacity="0"
                    IsHitTestVisible="False"/>
        </Grid>
    </Border>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Ring Elastic Scale Up -->
                    <DoubleAnimation Storyboard.TargetName="SuccessRing"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                     From="0" To="1" Duration="0:0:0.8">
                        <DoubleAnimation.EasingFunction>
                            <ElasticEase Oscillations="1" Springiness="4" EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="SuccessRing"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     From="0" To="1" Duration="0:0:0.8">
                        <DoubleAnimation.EasingFunction>
                            <ElasticEase Oscillations="1" Springiness="4" EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- "Let's Go!" Button delay and fade-in -->
                    <DoubleAnimation Storyboard.TargetName="LetsGoButton"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" BeginTime="0:0:3.5" Duration="0:0:0.5"/>
                    <BooleanAnimationUsingKeyFrames Storyboard.TargetName="LetsGoButton" Storyboard.TargetProperty="IsHitTestVisible">
                        <DiscreteBooleanKeyFrame KeyTime="0:0:3.5" Value="True"/>
                    </BooleanAnimationUsingKeyFrames>

                    <!-- Confetti 1 Opacity & Translations (Yellow) -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="confetti1" Storyboard.TargetProperty="Opacity">
                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:3.0" Value="1"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="0"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="c1" Storyboard.TargetProperty="X">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="-60">
                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="-75"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="c1" Storyboard.TargetProperty="Y">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="-45">
                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="25"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="cr1" Storyboard.TargetProperty="Angle">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="360"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- Confetti 2 Opacity & Translations (Red) -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="confetti2" Storyboard.TargetProperty="Opacity">
                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:3.0" Value="1"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="0"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="c2" Storyboard.TargetProperty="X">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="-40">
                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="-50"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="c2" Storyboard.TargetProperty="Y">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="40">
                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="95"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- Confetti 3 Opacity & Translations (Green) -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="confetti3" Storyboard.TargetProperty="Opacity">
                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:3.0" Value="1"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="0"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="c3" Storyboard.TargetProperty="X">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="65">
                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="75"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="c3" Storyboard.TargetProperty="Y">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="-50">
                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="20"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="cr3" Storyboard.TargetProperty="Angle">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="-240"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- Confetti 4 Opacity & Translations (Purple) -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="confetti4" Storyboard.TargetProperty="Opacity">
                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:3.0" Value="1"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="0"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="c4" Storyboard.TargetProperty="X">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="50">
                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="60"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="c4" Storyboard.TargetProperty="Y">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="35">
                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="90"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- Confetti 5 Opacity & Translations (Bright Green) -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="confetti5" Storyboard.TargetProperty="Opacity">
                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:3.0" Value="1"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="0"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="c5" Storyboard.TargetProperty="X">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="10">
                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="5"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="c5" Storyboard.TargetProperty="Y">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="-65">
                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                        </EasingDoubleKeyFrame>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="0"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="cr5" Storyboard.TargetProperty="Angle">
                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0"/>
                        <LinearDoubleKeyFrame KeyTime="0:0:4.0" Value="600"/>
                    </DoubleAnimationUsingKeyFrames>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
