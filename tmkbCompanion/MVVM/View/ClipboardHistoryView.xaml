<UserControl x:Class="tmkbCompanion.MVVM.View.ClipboardHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             d:DesignHeight="500" d:DesignWidth="640">

    <Grid Margin="16,12">
        <Grid.RowDefinitions>
            <!-- Header section -->
            <RowDefinition Height="Auto"/>
            <!-- Spacer -->
            <RowDefinition Height="12"/>
            <!-- History list -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                           Text="&#xF0EA;" 
                           FontSize="24" 
                           Foreground="{DynamicResource AccentBrush}" 
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Clipboard History" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               FontFamily="{StaticResource AppFont}"/>
                    <TextBlock Text="Store, manage, and retrieve items you copy system-wide" 
                               Foreground="{StaticResource TextMutedBrush}" 
                               FontSize="11" 
                               Opacity="0.7"
                               FontFamily="{StaticResource AppFont}"/>
                </StackPanel>
            </StackPanel>

            <Button Content="Clear All" 
                    Command="{Binding ClearHistoryCommand}"
                    Style="{StaticResource FluentButtonSecondary}"
                    Height="32" Padding="12,0" FontSize="12"
                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <!-- Empty state when no items -->
            <TextBlock Text="Clipboard history is empty. Press Ctrl+C in any app to save snippets here!"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="14"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="30,0"
                       FontFamily="{StaticResource AppFont}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ClipboardItems.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Scrollable History List -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" FocusVisualStyle="{x:Null}">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ClipboardItems.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                
                <ItemsControl ItemsSource="{Binding ClipboardItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Card item -->
                            <Border Style="{StaticResource ThreeDCardStyle}" 
                                    Padding="14" 
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Content snippet -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding DisplaySnippet}" 
                                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                                   FontSize="14" 
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   FontFamily="{StaticResource AppFont}"/>
                                        
                                        <TextBlock Text="{Binding FormattedTime}" 
                                                   Foreground="{StaticResource TextMutedBrush}" 
                                                   FontSize="11" 
                                                   Opacity="0.75"
                                                   Margin="0,4,0,0"
                                                   FontFamily="{StaticResource AppFont}"/>
                                    </StackPanel>

                                    <!-- Action Buttons -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Copy item back -->
                                        <Button Width="36" Height="36" Margin="0,0,6,0"
                                                ToolTip="Copy back to clipboard"
                                                Command="{Binding DataContext.CopyItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource FluentButtonTransparentPrimary}">
                                            <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                                       Text="&#xF0EA;" 
                                                       FontSize="14" 
                                                       VerticalAlignment="Center" 
                                                       HorizontalAlignment="Center"/>
                                        </Button>

                                        <!-- Delete item -->
                                        <Button Width="36" Height="36"
                                                ToolTip="Delete from history"
                                                Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource FluentButtonSecondary}">
                                            <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                                       Text="&#xF1F8;" 
                                                       FontSize="14" 
                                                       Foreground="#ff5252"
                                                       VerticalAlignment="Center" 
                                                       HorizontalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
