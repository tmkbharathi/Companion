<Window x:Class="tmkbCompanion.MVVM.View.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="App Update" 
        Height="300" Width="440"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        MouseDown="Window_MouseDown"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Theme/ThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Drop shadow outer wrapper -->
    <Border Background="#151925" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1.5" 
            CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="6" Opacity="0.55"/>
        </Border.Effect>

        <Grid Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <!-- Header (Title & Close) -->
                <RowDefinition Height="Auto"/>
                <!-- Body (Message) -->
                <RowDefinition Height="*"/>
                <!-- Actions or Progress -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Row 0: Title & Close ── -->
            <Grid Grid.Row="0">
                <StackPanel>
                    <TextBlock Text="Update Available" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               FontFamily="{StaticResource AppFont}"/>
                    <TextBlock x:Name="VersionText" 
                               Text="New version is ready to install" 
                               Foreground="{StaticResource TextMutedBrush}" 
                               FontSize="12" 
                               Margin="0,4,0,0"
                               FontFamily="{StaticResource AppFont}"/>
                </StackPanel>

                <!-- X close button (top-right) -->
                <Button x:Name="CloseButton"
                        FontFamily="{StaticResource SegoeMDL2}"
                        Content="&#xF00D;"
                        FontSize="14"
                        Foreground="{StaticResource TextMutedBrush}"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top" 
                        Click="Cancel_Click"
                        Width="28" Height="28"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btnBg"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btnBg" Property="Background" Value="#2a303f"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- ── Row 1: Message / Details ── -->
            <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Update Icon -->
                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Border Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="10" Width="44" Height="44"/>
                    <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE896;" FontSize="20" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="An update is ready for FlowTrack." 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               TextWrapping="Wrap"
                               FontFamily="{StaticResource AppFont}"/>
                    <TextBlock Text="Installing the latest version provides you with new features, bug fixes, and security enhancements." 
                               Foreground="{StaticResource TextMutedBrush}" 
                               FontSize="11" 
                               TextWrapping="Wrap"
                               Opacity="0.85" 
                               Margin="0,4,0,0" 
                               FontFamily="{StaticResource AppFont}"/>
                </StackPanel>
            </Grid>

            <!-- ── Row 2: Action Buttons OR Progress Bar ── -->
            <StackPanel Grid.Row="2">
                <!-- Do not show again checkbox -->
                <CheckBox x:Name="DoNotShowAgainCheckBox"
                          Content="Do not show again"
                          Foreground="{StaticResource TextMutedBrush}"
                          FontSize="11"
                          Margin="0,0,0,12"
                          HorizontalAlignment="Left"
                          Visibility="Collapsed"
                          FontFamily="{StaticResource AppFont}"/>

                <!-- Action Buttons Container -->
                <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="LaterButton"
                            Style="{StaticResource FluentButtonSecondary}"
                            Content="Update Later"
                            Click="Cancel_Click"
                            MinWidth="130" Height="36"
                            Padding="12,4"
                            Margin="0,0,10,0"/>
                    <Button Style="{StaticResource FluentButton}"
                            Content="Update Now"
                            Click="UpdateNow_Click"
                            MinWidth="130" Height="36"
                            Padding="12,4"/>
                </StackPanel>

                <!-- Progress Container (Initially Collapsed) -->
                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed">
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Downloading update..." 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   FontSize="12" 
                                   FontFamily="{StaticResource AppFont}"/>
                        <TextBlock x:Name="PercentText" 
                                   Text="0%" 
                                   Foreground="{DynamicResource AccentBrush}" 
                                   FontSize="12" 
                                   FontWeight="Bold" 
                                   HorizontalAlignment="Right" 
                                   FontFamily="{StaticResource AppFont}"/>
                    </Grid>
                    <ProgressBar x:Name="DownloadProgressBar" 
                                 Style="{StaticResource FluentProgressBar}" 
                                 Height="8" 
                                 Value="0" 
                                 Maximum="100"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
