<UserControl x:Class="tmkbCompanion.MVVM.View.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:tmkbCompanion.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" FocusVisualStyle="{x:Null}">
        <Grid Margin="40,40,40,60">
            <Grid.RowDefinitions>
            <!-- Header Section -->
            <RowDefinition Height="Auto"/>
            <!-- Content Grid -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Margin="0,0,0,40">
            <TextBlock Text="Good morning, Alex" 
                       Foreground="{StaticResource TextPrimaryBrush}" 
                       FontSize="48" 
                       FontWeight="Bold" 
                       FontFamily="{StaticResource AppFont}"/>
            <TextBlock Text="{Binding DataContext.CurrentDate, RelativeSource={RelativeSource AncestorType=Window}}" 
                       Foreground="{StaticResource TextMutedBrush}" 
                       FontSize="22" 
                       Opacity="0.8"
                       Margin="0,8,0,0"
                       FontFamily="{StaticResource AppFont}"/>
        </StackPanel>

        <!-- Content Grid -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Focus Timer Card (Column 0, Row 0) -->
            <Border Grid.Row="0" Grid.Column="0" 
                    Background="{StaticResource CardBackgroundBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="16" 
                    Padding="40" 
                    MinHeight="400">
                <Grid>
                    <!-- Background Icon Decoration -->
                    <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                               Text="&#xF1C5;" 
                               FontSize="400" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               Opacity="0.05" 
                               HorizontalAlignment="Right" 
                               VerticalAlignment="Bottom"
                               Margin="0,0,-40,-80"
                               IsHitTestVisible="False"/>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Header / Subtitle -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                       Text="&#xE916;" 
                                       FontSize="20" 
                                       Foreground="{DynamicResource AccentBrush}" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="FOCUS SESSION" 
                                       Foreground="{DynamicResource AccentBrush}" 
                                       FontSize="14" 
                                       FontWeight="Bold" 
                                       FontFamily="{StaticResource AppFont}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Timer Display -->
                        <TextBlock x:Name="TimerDisplay"
                                   Text="{Binding TimerText}" 
                                   Foreground="{DynamicResource AccentBrush}" 
                                   FontSize="140" 
                                   FontWeight="Bold" 
                                   HorizontalAlignment="Center"
                                   FontFamily="{StaticResource AppFont}">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <TextBlock Text="Stay focused on your current task." 
                                   Foreground="{StaticResource TextMutedBrush}" 
                                   FontSize="18" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,12,0,40"
                                   FontFamily="{StaticResource AppFont}"/>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <!-- Toggle Button (Play / Pause) -->
                            <Button Style="{StaticResource FluentButton}" 
                                    Command="{Binding ToggleTimerCommand}"
                                    Width="160" Height="48" Margin="0,0,16,0">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="TimerButtonIcon" 
                                                   FontFamily="{StaticResource SegoeMDL2}" 
                                                   FontSize="18" 
                                                   VerticalAlignment="Center" 
                                                   Margin="0,0,8,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#xE768;"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTimerRunning}" Value="True">
                                                            <Setter Property="Text" Value="&#xE71A;"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock x:Name="TimerButtonText" 
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Start"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTimerRunning}" Value="True">
                                                            <Setter Property="Text" Value="Pause"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            
                            <!-- Reset Button -->
                            <Button Style="{StaticResource FluentButtonSecondary}" 
                                    Command="{Binding ResetTimerCommand}"
                                    Content="Reset" 
                                    Width="120" Height="48"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Quick Notes Card (Column 2, Row 0) -->
            <Border Grid.Row="0" Grid.Column="2" 
                    Background="{StaticResource CardBackgroundBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="16" 
                    Padding="24"
                    MinHeight="400">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                       Text="&#xE70F;" 
                                       FontSize="24" 
                                       Foreground="{DynamicResource AccentBrush}" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Quick Notes" 
                                       Foreground="{StaticResource TextPrimaryBrush}" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       FontFamily="{StaticResource AppFont}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                   Text="&#xE946;" 
                                   FontSize="20" 
                                   Foreground="{StaticResource TextMutedBrush}" 
                                   Opacity="0.4"
                                   HorizontalAlignment="Right" 
                                   VerticalAlignment="Center"
                                   ToolTip="Saved locally in flowtrack_notes.txt"/>
                    </Grid>

                    <!-- Input Notes Area -->
                    <TextBox Grid.Row="1" 
                             Style="{StaticResource FluentTextBox}" 
                             Text="{Binding NotesText, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" 
                             AcceptsReturn="True" 
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,16"/>

                    <!-- Save Action Button -->
                    <Button Grid.Row="2" 
                            x:Name="SaveNotesBtn"
                            Command="{Binding SaveNotesCommand}"
                            Height="48">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FluentButtonTransparentPrimary}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSavedFeedbackActive}" Value="True">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#10b981" Opacity="0.15"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="#10b981"/>
                                        <Setter Property="BorderBrush">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#10b981" Opacity="0.3"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="SaveIcon" 
                                           FontFamily="{StaticResource SegoeMDL2}" 
                                           FontSize="18" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,8,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#xE74E;"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSavedFeedbackActive}" Value="True">
                                                    <Setter Property="Text" Value="&#xE930;"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding SaveButtonText}" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </Grid>
            </Border>

            <!-- Important Links Grid (Row 2, Column Span 3) -->
            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                    Background="{StaticResource CardBackgroundBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="16" 
                    Padding="24">
                <StackPanel>
                    <!-- Section Title -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                   Text="&#xE71B;" 
                                   FontSize="24" 
                                   Foreground="{DynamicResource AccentBrush}" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Important Links" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   FontFamily="{StaticResource AppFont}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Links Grid -->
                    <UniformGrid Columns="4" Rows="1" Height="90">
                        <!-- Company Portal -->
                        <Border Style="{StaticResource LinkCardBorder}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding OpenLinkCommand}" CommandParameter="https://portal.company.com"/>
                            </Border.InputBindings>
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="6" Width="40" Height="40" Grid.Column="0"/>
                                <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE80F;" FontSize="20" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0"/>
                                <TextBlock Text="Company Portal" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontFamily="{StaticResource AppFont}" FontWeight="Medium" VerticalAlignment="Center" Margin="12,0,0,0" Grid.Column="1"/>
                            </Grid>
                        </Border>

                        <!-- Documentation -->
                        <Border Style="{StaticResource LinkCardBorder}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding OpenLinkCommand}" CommandParameter="https://docs.company.com"/>
                            </Border.InputBindings>
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="6" Width="40" Height="40" Grid.Column="0"/>
                                <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE8C7;" FontSize="20" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0"/>
                                <TextBlock Text="Documentation" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontFamily="{StaticResource AppFont}" FontWeight="Medium" VerticalAlignment="Center" Margin="12,0,0,0" Grid.Column="1"/>
                            </Grid>
                        </Border>

                        <!-- Task Tracker -->
                        <Border Style="{StaticResource LinkCardBorder}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding OpenLinkCommand}" CommandParameter="https://tasks.company.com"/>
                            </Border.InputBindings>
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="6" Width="40" Height="40" Grid.Column="0"/>
                                <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE73A;" FontSize="20" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0"/>
                                <TextBlock Text="Task Tracker" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontFamily="{StaticResource AppFont}" FontWeight="Medium" VerticalAlignment="Center" Margin="12,0,0,0" Grid.Column="1"/>
                            </Grid>
                        </Border>

                        <!-- Team Calendar -->
                        <Border Style="{StaticResource LinkCardBorder}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding OpenLinkCommand}" CommandParameter="https://calendar.company.com"/>
                            </Border.InputBindings>
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="6" Width="40" Height="40" Grid.Column="0"/>
                                <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE787;" FontSize="20" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0"/>
                                <TextBlock Text="Team Calendar" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontFamily="{StaticResource AppFont}" FontWeight="Medium" VerticalAlignment="Center" Margin="12,0,0,0" Grid.Column="1"/>
                            </Grid>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</ScrollViewer>
</UserControl>
