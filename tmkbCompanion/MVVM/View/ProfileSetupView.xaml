<UserControl x:Class="tmkbCompanion.MVVM.View.ProfileSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:tmkbCompanion.MVVM.View"
             mc:Ignorable="d"
             d:DesignHeight="468" d:DesignWidth="640">

    <!--
        Layout budget (window 500 – titlebar 32 = 468 px available height):
          outer margin 8 top/bottom     →  452 px inner
          card padding  14 top/bottom   →  424 px for content
            header block                →  ~42 px
            spacer                      →    6 px
            main 2-col grid             →  ~320 px
            footer bar                  →  ~56 px
          Total                         ≈  424 px  ✓ fits without scrolling
    -->
    <Border BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Margin="10,8,10,8"
            Padding="16,14,16,14">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1c2230" Offset="0"/>
                <GradientStop Color="#151925" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Header: title + subtitle -->
                <RowDefinition Height="Auto"/>
                <!-- Spacer -->
                <RowDefinition Height="8"/>
                <!-- Main two-column content -->
                <RowDefinition Height="*"/>
                <!-- Footer action buttons -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══════════ Row 0: Header ═══════════ -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                <TextBlock Text="Setup your Profile"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="20"
                           FontWeight="Bold"
                           FontFamily="{StaticResource AppFont}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Personalize your FlowTrack experience."
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"
                           Margin="0,3,0,0"
                           FontFamily="{StaticResource AppFont}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ═══════════ Row 2: Two-column content ═══════════ -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <!-- Left: profile photo -->
                    <ColumnDefinition Width="130"/>
                    <!-- Gap -->
                    <ColumnDefinition Width="14"/>
                    <!-- Right: form fields -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Left: Profile Photo ── -->
                <StackPanel Grid.Column="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Grid Width="110" Height="110">
                        <!-- Dashed ring -->
                        <Ellipse Stroke="#434653" StrokeThickness="2" StrokeDashArray="3 2"/>

                        <!-- Photo / default icon -->
                        <Border Margin="4" CornerRadius="51" ClipToBounds="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#0c0e15"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasProfilePicture}" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <ImageBrush ImageSource="{Binding ProfilePicturePath,
                                                                              UpdateSourceTrigger=PropertyChanged}"
                                                                Stretch="UniformToFill"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontFamily="{StaticResource SegoeMDL2}"
                                       Text="&#xE77B;"
                                       FontSize="44"
                                       Foreground="#8d909f"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasProfilePicture}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <!-- Camera overlay button -->
                        <Button Width="30" Height="30"
                                Command="{Binding UploadPictureCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,2,2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBorder"
                                            Background="{DynamicResource AccentBrush}"
                                            CornerRadius="15"
                                            SnapsToDevicePixels="True">
                                        <TextBlock FontFamily="{StaticResource SegoeMDL2}"
                                                   Text="&#xE722;"
                                                   FontSize="12"
                                                   Foreground="#001847"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.85"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Upload link -->
                    <TextBlock Text="Upload Photo"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="11"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"
                               Cursor="Hand"
                               Margin="0,8,0,0">
                        <TextBlock.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding UploadPictureCommand}"/>
                        </TextBlock.InputBindings>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="TextDecorations" Value="Underline"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- ── Right: Form Fields ── -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">

                    <!-- Display Name -->
                    <TextBlock Text="Display Name"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               FontWeight="Medium"
                               Margin="2,0,0,4"
                               FontFamily="{StaticResource AppFont}"/>
                    <TextBox Style="{StaticResource ProfileInputTextBox}"
                             Tag="e.g. Alex Rivera"
                             Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             Padding="10,5"
                             FontSize="13"
                             Margin="0,0,0,10"
                             MaxLength="20"/>

                    <!-- Bio -->
                    <TextBlock Text="Bio"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               FontWeight="Medium"
                               Margin="2,0,0,4"
                               FontFamily="{StaticResource AppFont}"/>
                    <TextBox Style="{StaticResource ProfileInputTextArea}"
                             Tag="Tell us about your workflow..."
                             Text="{Binding Bio, UpdateSourceTrigger=PropertyChanged}"
                             Height="44"
                             Padding="10,5"
                             FontSize="13"
                             Margin="0,0,0,10"/>

                    <!-- Productivity Goals -->
                    <TextBlock Text="Productivity Goals"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               FontWeight="Medium"
                               Margin="2,0,0,6"
                               FontFamily="{StaticResource AppFont}"/>

                    <UniformGrid Columns="3" Rows="1" Height="52" Margin="0,0,0,10">

                        <ToggleButton Style="{StaticResource GoalCardStyle}"
                                      IsChecked="{Binding IsDeepWorkSelected}"
                                      Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock FontFamily="{StaticResource SegoeMDL2}"
                                           Text="&#xE945;" FontSize="16"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,3"/>
                                <TextBlock Text="Deep Work"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="10" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           FontFamily="{StaticResource AppFont}"/>
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton Style="{StaticResource GoalCardStyle}"
                                      IsChecked="{Binding IsTasksSelected}"
                                      Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock FontFamily="{StaticResource SegoeMDL2}"
                                           Text="&#xE73A;" FontSize="16"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,3"/>
                                <TextBlock Text="Tasks"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="10" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           FontFamily="{StaticResource AppFont}"/>
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton Style="{StaticResource GoalCardStyle}"
                                      IsChecked="{Binding IsMeetingsSelected}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock FontFamily="{StaticResource SegoeMDL2}"
                                           Text="&#xE716;" FontSize="16"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,3"/>
                                <TextBlock Text="Meetings"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="10" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           FontFamily="{StaticResource AppFont}"/>
                            </StackPanel>
                        </ToggleButton>
                    </UniformGrid>

                    <!-- Smart Notifications toggle -->
                    <Border Background="#0c0e15"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,8"
                            Opacity="0.9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{StaticResource SidebarBackgroundBrush}"
                                    CornerRadius="6" Width="28" Height="28"
                                    Margin="0,0,10,0">
                                <TextBlock FontFamily="{StaticResource SegoeMDL2}"
                                           Text="&#xEA8F;" FontSize="14"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Enable smart notifications"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12" FontWeight="Bold"
                                           FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="Suggest focus times based on your calendar."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="10" Opacity="0.8"
                                           Margin="0,1,0,0"
                                           FontFamily="{StaticResource AppFont}"/>
                            </StackPanel>

                            <CheckBox Grid.Column="2"
                                      Style="{StaticResource FluentToggleSwitch}"
                                      IsChecked="{Binding IsSmartNotificationsEnabled}"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </Grid>

            <!-- ═══════════ Row 3: Footer Buttons ═══════════ -->
            <Border Grid.Row="3"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Margin="0,10,0,0"
                    Padding="0,10,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Skip for Now"
                            Command="{Binding SkipCommand}"
                            Style="{StaticResource FluentButtonSecondary}"
                            Width="120" Height="34"
                            Margin="0,0,10,0"/>
                    <Button Command="{Binding SaveProfileCommand}"
                            Style="{StaticResource FluentButton}"
                            Width="150" Height="34">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Save Profile" VerticalAlignment="Center"/>
                                <TextBlock FontFamily="{StaticResource SegoeMDL2}"
                                           Text="&#xE72A;" FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</UserControl>
