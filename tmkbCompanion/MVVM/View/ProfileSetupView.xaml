<UserControl x:Class="tmkbCompanion.MVVM.View.ProfileSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:tmkbCompanion.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" FocusVisualStyle="{x:Null}">
        <Grid Margin="40,40,40,60">
            <!-- Container with Gradient Background -->
            <Border BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="16" 
                    MaxWidth="800"
                    HorizontalAlignment="Center"
                    Padding="40">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1c2230" Offset="0"/>
                        <GradientStop Color="#151925" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="25" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Header -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,40">
                        <TextBlock Text="Setup your Profile" 
                                   Foreground="{DynamicResource AccentBrush}" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   FontFamily="{StaticResource AppFont}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Personalize your FlowTrack experience." 
                                   Foreground="{StaticResource TextMutedBrush}" 
                                   FontSize="16" 
                                   Margin="0,8,0,0"
                                   FontFamily="{StaticResource AppFont}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Main Columns Grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Profile Picture -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,24,0">
                            <Grid Width="160" Height="160">
                                <!-- Dashed Circle outline -->
                                <Ellipse Stroke="#434653" StrokeThickness="2" StrokeDashArray="3 2" />
                                
                                <!-- Profile image container -->
                                <Border CornerRadius="80" ClipToBounds="True" Background="#0c0e15" Margin="4">
                                    <Grid>
                                        <!-- Default account_circle icon -->
                                        <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                                   Text="&#xE77B;" 
                                                   FontSize="64" 
                                                   Foreground="#8d909f" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasProfilePicture}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Uploaded Photo -->
                                        <Image Source="{Binding ProfilePicturePath, UpdateSourceTrigger=PropertyChanged}" 
                                               Stretch="UniformToFill">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasProfilePicture}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Grid>
                                </Border>

                                <!-- Camera Overlay Button -->
                                <Button Width="40" Height="40" 
                                        Command="{Binding UploadPictureCommand}"
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,4,4">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="btnBorder" Background="{DynamicResource AccentBrush}" CornerRadius="20" SnapsToDevicePixels="True">
                                                <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                                           Text="&#xE722;" 
                                                           FontSize="16" 
                                                           Foreground="#001847" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="btnBorder" Property="Opacity" Value="0.9"/>
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Upload Text link -->
                            <TextBlock Text="Upload New Photo" 
                                       Foreground="{DynamicResource AccentBrush}" 
                                       FontSize="12" 
                                       FontWeight="Medium" 
                                       HorizontalAlignment="Center" 
                                       Cursor="Hand"
                                       Margin="0,16,0,0">
                                <TextBlock.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding UploadPictureCommand}"/>
                                </TextBlock.InputBindings>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Right Column: User Info & Goals -->
                        <StackPanel Grid.Column="1" Margin="24,0,0,0">
                            <!-- Display Name Input -->
                            <TextBlock Text="Display Name" 
                                       Foreground="{StaticResource TextMutedBrush}" 
                                       FontSize="13" 
                                       FontWeight="Medium" 
                                       Margin="2,0,0,8"
                                       FontFamily="{StaticResource AppFont}"/>
                            <TextBox Style="{StaticResource ProfileInputTextBox}" 
                                     Tag="e.g. Alex Rivera" 
                                     Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,24"/>

                            <!-- Bio Input -->
                            <TextBlock Text="Bio" 
                                       Foreground="{StaticResource TextMutedBrush}" 
                                       FontSize="13" 
                                       FontWeight="Medium" 
                                       Margin="2,0,0,8"
                                       FontFamily="{StaticResource AppFont}"/>
                            <TextBox Style="{StaticResource ProfileInputTextArea}" 
                                     Tag="Tell us about your workflow..." 
                                     Height="90"
                                     Text="{Binding Bio, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,28"/>

                            <!-- Productivity Goals -->
                            <TextBlock Text="Productivity Goals" 
                                       Foreground="{StaticResource TextMutedBrush}" 
                                       FontSize="13" 
                                       FontWeight="Medium" 
                                       Margin="2,0,0,12"
                                       FontFamily="{StaticResource AppFont}"/>
                            
                            <UniformGrid Columns="3" Rows="1" Height="80" Margin="0,0,0,28">
                                <!-- Deep Work Goal -->
                                <ToggleButton Style="{StaticResource GoalCardStyle}" 
                                              IsChecked="{Binding IsDeepWorkSelected}"
                                              Margin="0,0,8,0">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                                   Text="&#xE945;" 
                                                   FontSize="20" 
                                                   Foreground="{DynamicResource AccentBrush}" 
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Deep Work" 
                                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   FontFamily="{StaticResource AppFont}"/>
                                    </StackPanel>
                                </ToggleButton>

                                <!-- Tasks Goal -->
                                <ToggleButton Style="{StaticResource GoalCardStyle}" 
                                              IsChecked="{Binding IsTasksSelected}"
                                              Margin="0,0,8,0">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                                   Text="&#xE73A;" 
                                                   FontSize="20" 
                                                   Foreground="{DynamicResource AccentBrush}" 
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Tasks" 
                                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   FontFamily="{StaticResource AppFont}"/>
                                    </StackPanel>
                                </ToggleButton>

                                <!-- Meetings Goal -->
                                <ToggleButton Style="{StaticResource GoalCardStyle}" 
                                              IsChecked="{Binding IsMeetingsSelected}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                                   Text="&#xE716;" 
                                                   FontSize="20" 
                                                   Foreground="{DynamicResource AccentBrush}" 
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Meetings" 
                                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   FontFamily="{StaticResource AppFont}"/>
                                    </StackPanel>
                                </ToggleButton>
                            </UniformGrid>

                            <!-- Notifications Settings Toggle Card -->
                            <Border Background="#0c0e15" 
                                    BorderBrush="{StaticResource BorderBrush}" 
                                    BorderThickness="1" 
                                    CornerRadius="10" 
                                    Padding="16"
                                    Opacity="0.85">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Bell Icon -->
                                    <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}" CornerRadius="6" Width="36" Height="36" Margin="0,0,16,0">
                                        <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                                   Text="&#xEA8F;" 
                                                   FontSize="18" 
                                                   Foreground="{StaticResource TextMutedBrush}" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Text Content -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Enable smart notifications" 
                                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                                   FontSize="14" 
                                                   FontWeight="Bold"
                                                   FontFamily="{StaticResource AppFont}"/>
                                        <TextBlock Text="FlowTrack will suggest focus times based on your calendar." 
                                                   Foreground="{StaticResource TextMutedBrush}" 
                                                   FontSize="11" 
                                                   Opacity="0.8"
                                                   Margin="0,2,0,0"
                                                   FontFamily="{StaticResource AppFont}"/>
                                    </StackPanel>

                                    <!-- Toggle Switch -->
                                    <CheckBox Grid.Column="2" 
                                              Style="{StaticResource FluentToggleSwitch}" 
                                              IsChecked="{Binding IsSmartNotificationsEnabled}"/>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Grid>

                    <!-- Footer Action Buttons -->
                    <Border BorderBrush="{StaticResource BorderBrush}" 
                            BorderThickness="0,1,0,0" 
                            Margin="0,32,0,0" 
                            Padding="0,24,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Skip for Now" 
                                    Command="{Binding SkipCommand}"
                                    Style="{StaticResource FluentButtonSecondary}"
                                    Width="130" Height="42" 
                                    Margin="0,0,12,0"/>
                            
                            <Button Command="{Binding SaveProfileCommand}"
                                    Style="{StaticResource FluentButton}"
                                    Width="160" Height="42">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Save Profile" VerticalAlignment="Center"/>
                                        <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                                   Text="&#xE72A;" 
                                                   FontSize="14" 
                                                   VerticalAlignment="Center" 
                                                   Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
