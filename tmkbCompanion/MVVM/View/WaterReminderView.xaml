<UserControl x:Class="tmkbCompanion.MVVM.View.WaterReminderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:tmkbCompanion.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" FocusVisualStyle="{x:Null}">
        <Grid Margin="16,12,16,20">
            <Grid.RowDefinitions>
                <!-- Title / Greeting -->
                <RowDefinition Height="Auto"/>
                <!-- Main Grid -->
                <RowDefinition Height="Auto"/>
                <!-- Spacer -->
                <RowDefinition Height="16"/>
                <!-- History & Settings Section -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ════════════════════════════════ -->
            <!--  Header Block                    -->
            <!-- ════════════════════════════════ -->
            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="Water Hydration Reminder" 
                           Foreground="{StaticResource TextPrimaryBrush}" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           FontFamily="{StaticResource AppFont}"/>
                <TextBlock Text="{Binding MotivationalQuote}" 
                           Foreground="{DynamicResource AccentBrush}" 
                           FontSize="12" 
                           FontWeight="Medium"
                           Margin="0,3,0,0" 
                           FontFamily="{StaticResource AppFont}"/>
            </StackPanel>

            <!-- ════════════════════════════════ -->
            <!--  Main Content Split              -->
            <!-- ════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Left: Water Bottle + Log buttons -->
                    <ColumnDefinition Width="220"/>
                    <!-- Gap -->
                    <ColumnDefinition Width="16"/>
                    <!-- Right: Dashboard Stats + Timers -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column Card -->
                <Border Grid.Column="0" Style="{StaticResource ThreeDCardStyle}" Padding="16">
                    <StackPanel HorizontalAlignment="Center">
                        
                        <!-- Water Bottle Visualizer -->
                        <Grid Margin="0,10,0,18" Height="240" Width="100">
                            <!-- Bottle Neck/Cap -->
                            <Border Width="24" Height="12" 
                                    Background="#4b5563" 
                                    CornerRadius="3" 
                                    VerticalAlignment="Top" 
                                    HorizontalAlignment="Center" 
                                    Margin="0,0,0,0"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"/>
                            
                            <Border Width="34" Height="6" 
                                    Background="#374151" 
                                    CornerRadius="1" 
                                    VerticalAlignment="Top" 
                                    HorizontalAlignment="Center" 
                                    Margin="0,10,0,0"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"/>

                            <!-- Main Bottle Body -->
                            <Border Width="80" Height="214" 
                                    CornerRadius="20" 
                                    BorderBrush="{DynamicResource AccentBrush}" 
                                    BorderThickness="3" 
                                    Background="#0c0e15" 
                                    VerticalAlignment="Bottom" 
                                    ClipToBounds="True">
                                <Border.Effect>
                                    <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="15" ShadowDepth="0" Opacity="0.2"/>
                                </Border.Effect>
                                <Grid>
                                    <!-- Dynamic Water Layer -->
                                    <Grid VerticalAlignment="Bottom" Height="214">
                                        <Grid.RenderTransform>
                                            <ScaleTransform ScaleY="{Binding BottleFillRatio}" CenterY="214"/>
                                        </Grid.RenderTransform>
                                        <Border>
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#60a5fa" Offset="0"/>
                                                    <GradientStop Color="#1d4ed8" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#60a5fa" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                                            </Border.Effect>
                                        </Border>
                                    </Grid>

                                    <!-- Measurement Lines -->
                                    <StackPanel VerticalAlignment="Bottom" Height="214" Margin="0,0,0,0" IsHitTestVisible="False">
                                        <Border Height="1" Background="#ffffff" Opacity="0.25" Margin="0,53,0,0" Width="40" HorizontalAlignment="Right"/>
                                        <TextBlock Text="75%" FontSize="8" Foreground="#ffffff" Opacity="0.3" HorizontalAlignment="Right" Margin="0,-6,12,0"/>
                                        
                                        <Border Height="1" Background="#ffffff" Opacity="0.25" Margin="0,46,0,0" Width="40" HorizontalAlignment="Right"/>
                                        <TextBlock Text="50%" FontSize="8" Foreground="#ffffff" Opacity="0.3" HorizontalAlignment="Right" Margin="0,-6,12,0"/>
                                        
                                        <Border Height="1" Background="#ffffff" Opacity="0.25" Margin="0,46,0,0" Width="40" HorizontalAlignment="Right"/>
                                        <TextBlock Text="25%" FontSize="8" Foreground="#ffffff" Opacity="0.3" HorizontalAlignment="Right" Margin="0,-6,12,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Big Percentage Overlay inside bottle -->
                            <TextBlock Text="{Binding DisplayPercentage}" 
                                       Foreground="{StaticResource TextPrimaryBrush}" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" 
                                       Margin="0,20,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.75"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Grid>

                        <!-- Goal Progress Bar (Numerical) -->
                        <TextBlock Text="Intake Progress" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,8" HorizontalAlignment="Center">
                            <Run Text="{Binding TodayIntake, Mode=OneWay}"/>
                            <Run Text=" / " Foreground="{StaticResource TextMutedBrush}"/>
                            <Run Text="{Binding DailyGoal, Mode=OneWay}"/>
                            <Run Text=" ml" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                        </TextBlock>

                        <!-- Drink Buttons Grid -->
                        <UniformGrid Columns="2" Rows="2" Width="180" Height="70" Margin="0,0,0,10">
                            <Button Style="{StaticResource FluentButtonSecondary}" Content="+100 ml" Command="{Binding AddWaterCommand}" CommandParameter="100" Margin="2" Height="30"/>
                            <Button Style="{StaticResource FluentButtonSecondary}" Content="+250 ml" Command="{Binding AddWaterCommand}" CommandParameter="250" Margin="2" Height="30"/>
                            <Button Style="{StaticResource FluentButtonSecondary}" Content="+500 ml" Command="{Binding AddWaterCommand}" CommandParameter="500" Margin="2" Height="30"/>
                            <!-- Custom Quick Drink -->
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource FluentTextBox}" 
                                         Text="{Binding CustomDrinkAmount, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="4,2" 
                                         FontSize="11" 
                                         Height="30" 
                                         VerticalContentAlignment="Center" 
                                         HorizontalContentAlignment="Center"/>
                                <Button Grid.Column="1" 
                                        Style="{StaticResource FluentButton}" 
                                        Command="{Binding AddWaterCommand}" 
                                        Content="+" 
                                        Height="30" 
                                        Padding="0" 
                                        FontWeight="Bold"/>
                            </Grid>
                        </UniformGrid>

                    </StackPanel>
                </Border>

                <!-- Right Column Split -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <!-- Top: Target & Timers -->
                        <RowDefinition Height="Auto"/>
                        <!-- Spacer -->
                        <RowDefinition Height="12"/>
                        <!-- Bottom: Stats & Badges -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top row: Goal config & Timers -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Goal Settings Card -->
                        <Border Grid.Column="0" Style="{StaticResource ThreeDCardStyle}" Padding="12" MinHeight="160">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xEA8F;" FontSize="16" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Hydration Goal" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="Bold" FontFamily="{StaticResource AppFont}"/>
                                </StackPanel>

                                <!-- Goal setting input -->
                                <TextBlock Text="Daily Target (ml)" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="2,0,0,3"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Style="{StaticResource FluentTextBox}" Text="{Binding DailyGoal, UpdateSourceTrigger=LostFocus}" Height="32" Padding="8,4" VerticalContentAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="ml" VerticalAlignment="Center" Margin="8,0,4,0" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                </Grid>

                                <!-- Streak progress info -->
                                <Border Background="#0c0e15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10,6">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE785;" FontSize="14" Foreground="#ffb874" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Intake Streak" FontSize="11" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding CurrentStreak, StringFormat='{}{0} Days'}" Foreground="#ffb874" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Reminder Timer Control Card -->
                        <Border Grid.Column="2" Style="{StaticResource ThreeDCardStyle}" Padding="12" MinHeight="160">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: Configs & Stats -->
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE916;" FontSize="15" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Reminder Interval" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="Bold" FontFamily="{StaticResource AppFont}"/>
                                    </StackPanel>

                                    <!-- Interval Combobox -->
                                    <ComboBox SelectedIndex="{Binding SelectedIntervalIndex}" Height="28" Margin="0,0,0,6" Background="#0c0e15" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrush}">
                                        <ComboBoxItem Content="Every 15 Minutes"/>
                                        <ComboBoxItem Content="Every 30 Minutes"/>
                                        <ComboBoxItem Content="Every 1 Hour"/>
                                        <ComboBoxItem Content="Custom Interval"/>
                                    </ComboBox>

                                    <!-- Custom Input minutes -->
                                    <Grid Visibility="{Binding SelectedIntervalIndex, Converter={StaticResource BoolToVis}, ConverterParameter=3}" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Style="{StaticResource FluentTextBox}" Text="{Binding CustomIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" Height="28" Padding="6,2" VerticalContentAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="min" VerticalAlignment="Center" Margin="6,0,2,0" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                    </Grid>

                                    <!-- Audio Alert Checkbox -->
                                    <CheckBox IsChecked="{Binding AudioAlertEnabled}" Content="Play sound alert" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="2,4,0,0"/>
                                </StackPanel>

                                <!-- Right: Large timer display & control buttons -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CountdownText}" Foreground="{DynamicResource AccentBrush}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="{StaticResource AppFont}">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                                        </TextBlock.Effect>
                                    </TextBlock>

                                    <!-- Start / Pause buttons -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                        <!-- Start -->
                                        <Button Style="{StaticResource FluentButton}" 
                                                Command="{Binding StartTimerCommand}" 
                                                Visibility="{Binding IsTimerRunning, Converter={StaticResource BoolToVis}, ConverterParameter=False}" 
                                                Content="Start" Width="60" Height="26" FontSize="11" Padding="0"/>
                                        <!-- Pause -->
                                        <Button Style="{StaticResource FluentButtonSecondary}" 
                                                Command="{Binding PauseTimerCommand}" 
                                                Visibility="{Binding IsTimerRunning, Converter={StaticResource BoolToVis}}" 
                                                Content="Pause" Width="60" Height="26" FontSize="11" Padding="0"/>
                                        
                                        <!-- Stop -->
                                        <Button Style="{StaticResource FluentButtonSecondary}" 
                                                Command="{Binding StopTimerCommand}" 
                                                Content="Stop" Width="50" Height="26" FontSize="11" Padding="0" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Bottom row: Details Stats & Badge Card -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Stats Dashboard Card -->
                        <Border Grid.Column="0" Style="{StaticResource ThreeDCardStyle}" Padding="12" MinHeight="150">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xF201;" FontSize="16" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Hydration Statistics" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="Bold" FontFamily="{StaticResource AppFont}"/>
                                </StackPanel>

                                <Grid Margin="0,2">
                                    <TextBlock Text="Remaining Target:" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding RemainingWater, StringFormat='{}{0} ml'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4"/>

                                <Grid Margin="0,2">
                                    <TextBlock Text="Last Drink Time:" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding LastDrinkTime}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4"/>

                                <Grid Margin="0,2">
                                    <TextBlock Text="Reminders Triggered:" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding RemindersSent}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4"/>

                                <Grid Margin="0,2">
                                    <TextBlock Text="Total Logged Drinks:" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding DrinksLogged}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Badges Milestone Card -->
                        <Border Grid.Column="2" Style="{StaticResource ThreeDCardStyle}" Padding="12" MinHeight="150">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE71A;" FontSize="15" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Hydration Milestones" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="Bold" FontFamily="{StaticResource AppFont}"/>
                                </StackPanel>

                                <UniformGrid Columns="3" Rows="1" Height="64">
                                    
                                    <!-- 50% Badge -->
                                    <StackPanel VerticalAlignment="Center">
                                        <Border Width="36" Height="36" CornerRadius="18" HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#33343c"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Is50PercentBadgeUnlocked}" Value="True">
                                                            <Setter Property="Background" Value="#1e3a8a"/>
                                                            <Setter Property="BorderBrush" Value="#3b82f6"/>
                                                            <Setter Property="BorderThickness" Value="1.5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE73A;" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#555555"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Is50PercentBadgeUnlocked}" Value="True">
                                                                <Setter Property="Foreground" Value="#60a5fa"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Text="50% Reached" FontSize="9" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- 75% Badge -->
                                    <StackPanel VerticalAlignment="Center">
                                        <Border Width="36" Height="36" CornerRadius="18" HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#33343c"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Is75PercentBadgeUnlocked}" Value="True">
                                                            <Setter Property="Background" Value="#5c3d00"/>
                                                            <Setter Property="BorderBrush" Value="#ffb874"/>
                                                            <Setter Property="BorderThickness" Value="1.5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE785;" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#555555"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Is75PercentBadgeUnlocked}" Value="True">
                                                                <Setter Property="Foreground" Value="#ffb874"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Text="75% Reached" FontSize="9" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- 100% Badge -->
                                    <StackPanel VerticalAlignment="Center">
                                        <Border Width="36" Height="36" CornerRadius="18" HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#33343c"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Is100PercentBadgeUnlocked}" Value="True">
                                                            <Setter Property="Background" Value="#064e3b"/>
                                                            <Setter Property="BorderBrush" Value="#10b981"/>
                                                            <Setter Property="BorderThickness" Value="1.5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE76E;" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#555555"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Is100PercentBadgeUnlocked}" Value="True">
                                                                <Setter Property="Foreground" Value="#10b981"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Text="100% Reached" FontSize="9" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>

                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ════════════════════════════════ -->
            <!--  History Log DataGrid            -->
            <!-- ════════════════════════════════ -->
            <Border Grid.Row="3" Style="{StaticResource ThreeDCardStyle}" Padding="16">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE81C;" FontSize="16" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Hydration History Logs" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="Bold" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>
                        <Button Style="{StaticResource FluentButtonSecondary}" 
                                Command="{Binding ExportCsvCommand}" 
                                HorizontalAlignment="Right" 
                                Height="28" 
                                Padding="12,0" 
                                FontSize="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xE896;" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Export History to CSV" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- History DataGrid -->
                    <DataGrid ItemsSource="{Binding HistoryList}" 
                              AutoGenerateColumns="False" 
                              Background="#0c0e15" 
                              BorderBrush="{StaticResource BorderBrush}" 
                              RowBackground="#151925" 
                              AlternatingRowBackground="#1a1e2b" 
                              Foreground="{StaticResource TextPrimaryBrush}" 
                              GridLinesVisibility="Horizontal" 
                              HorizontalGridLinesBrush="#2a3142" 
                              HeadersVisibility="Column" 
                              IsReadOnly="True" 
                              Height="140" 
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#1c2230"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="1.5*"/>
                            <DataGridTextColumn Header="Daily Target (ml)" Binding="{Binding Target}" Width="1.2*"/>
                            <DataGridTextColumn Header="Consumed Water (ml)" Binding="{Binding Consumed}" Width="1.5*"/>
                            <DataGridTextColumn Header="Completion (%)" Binding="{Binding Percentage, StringFormat='{}{0}%'}" Width="1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
