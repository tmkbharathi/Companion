<UserControl x:Class="tmkbCompanion.MVVM.View.RunScriptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:tmkbCompanion.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Theme/ThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" FocusVisualStyle="{x:Null}">
        <StackPanel Margin="20,20,20,30" MaxWidth="800" HorizontalAlignment="Left">
            
            <!-- SECTION Header -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Run Script" 
                           Foreground="{StaticResource TextPrimaryBrush}" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           FontFamily="{StaticResource AppFont}"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Configure and run custom scripts directly in the app or via the system tray."
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="13"
                           Margin="0,4,0,0"
                           FontFamily="{StaticResource AppFont}"/>
            </StackPanel>

            <!-- Card: Script Configuration -->
            <Border Style="{StaticResource ThreeDCardStyle}" 
                    Padding="16"
                    Margin="0,0,0,16">
                <StackPanel>
                    <!-- Terminal Selection & Window Setting Row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="Terminal:" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,12,0"
                                   FontFamily="{StaticResource AppFont}"/>

                        <ComboBox Grid.Column="1" 
                                  Style="{StaticResource FluentComboBox}"
                                  SelectedValuePath="Content"
                                  SelectedValue="{Binding TerminalType}"
                                  Height="32"
                                  VerticalContentAlignment="Center"
                                  Padding="8,4">
                            <ComboBoxItem Content="PowerShell"/>
                            <ComboBoxItem Content="Command Prompt"/>
                            <ComboBoxItem Content="Git Bash"/>
                        </ComboBox>

                        <CheckBox Grid.Column="3" 
                                  Content="Run in external window" 
                                  IsChecked="{Binding RunInExternalWindow}"
                                  Style="{StaticResource FluentToggleSwitch}"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Script Editor -->
                    <TextBlock Text="Script / Commands" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,8"
                               FontFamily="{StaticResource AppFont}"/>
                    
                    <TextBox Style="{StaticResource FluentTextBox}" 
                             Text="{Binding ScriptContent, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             Height="160"
                             FontFamily="Consolas"
                             FontSize="13"
                             Background="#1a1e2a"
                             Foreground="#c5cdd8"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Padding="10"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Clear Console" 
                                Command="{Binding ClearOutputCommand}"
                                Style="{StaticResource FluentButtonSecondary}"
                                MinWidth="130" Height="36"
                                Padding="12,4"
                                Margin="0,0,10,0"/>
                        
                        <Button Content="Stop Execution" 
                                Command="{Binding StopScriptCommand}"
                                Style="{StaticResource FluentButtonSecondary}"
                                MinWidth="130" Height="36"
                                Padding="12,4"
                                Margin="0,0,10,0"
                                Foreground="#ff5252"
                                Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>

                        <Button Content="Run Script" 
                                Command="{Binding RunScriptCommand}"
                                Style="{StaticResource FluentButton}"
                                MinWidth="130" Height="36"
                                Padding="12,4"
                                IsEnabled="{Binding IsNotRunning}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Card: Console Output -->
            <Border Style="{StaticResource ThreeDCardStyle}" 
                    Padding="16">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Console Output" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource AppFont}"/>
                        
                        <!-- Status Badge -->
                        <Border HorizontalAlignment="Right" 
                                CornerRadius="4" 
                                Padding="8,4"
                                Background="#1e2535">
                            <TextBlock Text="{Binding StatusText}" 
                                       Foreground="{DynamicResource AccentBrush}" 
                                       FontSize="11" 
                                       FontWeight="Bold"
                                       FontFamily="{StaticResource AppFont}"/>
                        </Border>
                    </Grid>

                    <TextBox x:Name="ConsoleLogBox"
                             Text="{Binding ConsoleOutput, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             Height="220"
                             FontFamily="Consolas"
                             FontSize="12"
                             Background="#0c0e15"
                             Foreground="#a9b1d6"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Padding="10"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextChanged="ConsoleLogBox_TextChanged"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
