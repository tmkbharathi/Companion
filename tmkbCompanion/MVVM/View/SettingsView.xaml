<UserControl x:Class="tmkbCompanion.MVVM.View.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:tmkbCompanion.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" FocusVisualStyle="{x:Null}">
        <StackPanel Margin="20,20,20,30" MaxWidth="800" HorizontalAlignment="Left">
            
            <!-- SECTION: General Settings -->
            <StackPanel Margin="0,0,0,32">
                <Grid Margin="0,0,0,20">
                    <TextBlock Text="General Settings" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               FontFamily="{StaticResource AppFont}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"/>

                    <Button Content="Edit Profile Setup"
                            Command="{Binding DataContext.ShowProfileSetupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource FluentButtonSecondary}"
                            Height="32"
                            Padding="12,0"
                            FontSize="12"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Card 1: Launch on Startup -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="8" Width="48" Height="48"/>
                        <TextBlock Grid.Column="0" FontFamily="{StaticResource SegoeMDL2}" Text="&#xF135;" FontSize="22" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Launch on Startup" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                            <TextBlock Text="Automatically open FlowTrack when you sign in" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Opacity="0.8" Margin="0,2,0,0" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>

                        <!-- Toggle -->
                        <CheckBox Grid.Column="2" Style="{StaticResource FluentToggleSwitch}" IsChecked="{Binding LaunchOnStartup}"/>
                    </Grid>
                </Border>

                <!-- Card 2: Show Notifications -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="8" Width="48" Height="48"/>
                        <TextBlock Grid.Column="0" FontFamily="{StaticResource SegoeMDL2}" Text="&#xF0F3;" FontSize="22" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Show Notifications" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                            <TextBlock Text="Receive alerts about system status and focus goals" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Opacity="0.8" Margin="0,2,0,0" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>

                        <!-- Toggle -->
                        <CheckBox Grid.Column="2" Style="{StaticResource FluentToggleSwitch}" IsChecked="{Binding ShowNotifications}"/>
                    </Grid>
                </Border>

                <!-- Card 3: Pet Companion -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="8" Width="48" Height="48"/>
                            <TextBlock Grid.Column="0" FontFamily="{StaticResource SegoeMDL2}" Text="&#xF1B0;" FontSize="22" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- Details -->
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Pet Companion" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock Text="Show a cute interactive cat that reacts to your typing" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Opacity="0.8" Margin="0,2,0,0" FontFamily="{StaticResource AppFont}"/>
                            </StackPanel>

                            <!-- Toggle -->
                            <CheckBox Grid.Column="2" Style="{StaticResource FluentToggleSwitch}" IsChecked="{Binding IsPetEnabled}"/>
                        </Grid>

                        <!-- Pet Type Selector (Visible when pet is enabled) -->
                        <StackPanel Visibility="{Binding IsPetEnabled, Converter={StaticResource BoolToVis}}" Margin="64,12,0,4">
                            <TextBlock Text="Render Mode" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="2D (Vector Bongo Cat)" IsChecked="{Binding Is2DPet}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}" FontSize="13" Margin="0,0,24,0"/>
                                <RadioButton Content="3D (Godot Engine)" IsChecked="{Binding Is3DPet}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="{StaticResource AppFont}" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Card 4: Quick Notes Path -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="8" Width="48" Height="48"/>
                        <TextBlock Grid.Column="0" FontFamily="{StaticResource SegoeMDL2}" Text="&#xF07C;" FontSize="22" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" Margin="16,0,16,0" VerticalAlignment="Center">
                            <TextBlock Text="Quick Notes Storage Location" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                            <TextBlock Text="{Binding DisplayNotesPath}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Opacity="0.8" Margin="0,2,0,0" FontFamily="{StaticResource AppFont}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Actions -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource FluentButtonSecondary}" Command="{Binding ResetNotesFolderCommand}" Content="Reset" Width="65" Height="30" Margin="0,0,8,0" FontSize="11" Padding="0"/>
                            <Button Style="{StaticResource FluentButton}" Command="{Binding BrowseNotesFolderCommand}" Content="Browse" Width="75" Height="30" FontSize="11" Padding="0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- SECTION: Appearance -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Appearance" 
                           Foreground="{StaticResource TextPrimaryBrush}" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           FontFamily="{StaticResource AppFont}"
                           Margin="0,0,0,20"/>

                <!-- Card 1: Dark Mode (Disabled) -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10"
                        Margin="0,0,0,12"
                        IsEnabled="False"
                        Opacity="0.5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="8" Width="48" Height="48"/>
                        <TextBlock Grid.Column="0" FontFamily="{StaticResource SegoeMDL2}" Text="&#xF186;" FontSize="22" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Dark Mode" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                           Text="&#xF05A;" 
                                           FontSize="14" 
                                           Foreground="{StaticResource TextMutedBrush}" 
                                           Opacity="0.8"
                                           VerticalAlignment="Center"
                                           Margin="8,2,0,0"
                                           Cursor="Help"
                                           ToolTipService.ShowOnDisabled="True"
                                           ToolTip="Later this feature will be enabled"/>
                            </StackPanel>
                            <TextBlock Text="Switch between light and dark visual themes" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Opacity="0.8" Margin="0,2,0,0" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>

                        <!-- Toggle -->
                        <CheckBox Grid.Column="2" Style="{StaticResource FluentToggleSwitch}" IsChecked="{Binding DarkMode}"/>
                    </Grid>
                </Border>

                <!-- Card 2: Accent Color -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="8" Width="48" Height="48"/>
                        <TextBlock Grid.Column="0" FontFamily="{StaticResource SegoeMDL2}" Text="&#xF53F;" FontSize="22" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Accent Color" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                            <TextBlock Text="Customize the primary highlights of the interface" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Opacity="0.8" Margin="0,2,0,0" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>

                        <!-- Colors Picker (2x2 Grid) -->
                        <Border Grid.Column="2" 
                                CornerRadius="8" 
                                ClipToBounds="True" 
                                Height="44" 
                                Width="44" 
                                BorderThickness="1" 
                                BorderBrush="{StaticResource BorderBrush}"
                                VerticalAlignment="Center">
                            <UniformGrid Columns="2" Rows="2">
                                <!-- Blue Accent -->
                                <Border Background="#5b8cff" Cursor="Hand" ToolTip="Accent Blue">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SetAccentColorCommand}" CommandParameter="#5b8cff"/>
                                    </Border.InputBindings>
                                </Border>
                                <!-- Red Accent -->
                                <Border Background="#ff5252" Cursor="Hand" ToolTip="Accent Red">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SetAccentColorCommand}" CommandParameter="#ff5252"/>
                                    </Border.InputBindings>
                                </Border>
                                <!-- Orange/Yellow Accent -->
                                <Border Background="#ffb874" Cursor="Hand" ToolTip="Accent Yellow">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SetAccentColorCommand}" CommandParameter="#ffb874"/>
                                    </Border.InputBindings>
                                </Border>
                                <!-- Green Accent -->
                                <Border Background="#10b981" Cursor="Hand" ToolTip="Accent Green">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SetAccentColorCommand}" CommandParameter="#10b981"/>
                                    </Border.InputBindings>
                                </Border>
                            </UniformGrid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- SECTION: Updates -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="App Updates" 
                           Foreground="{StaticResource TextPrimaryBrush}" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           FontFamily="{StaticResource AppFont}"
                           Margin="0,0,0,20"/>

                <!-- Update Card -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="8" Width="48" Height="48"/>
                        <TextBlock Grid.Column="0" FontFamily="{StaticResource SegoeMDL2}" Text="&#xE896;" FontSize="22" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Check for Updates" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                            <TextBlock Text="Check if there is a newer version of FlowTrack available" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Opacity="0.8" Margin="0,2,0,0" FontFamily="{StaticResource AppFont}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Button -->
                        <Button Grid.Column="2" 
                                Style="{StaticResource FluentButton}"
                                Command="{Binding CheckForUpdatesCommand}"
                                Content="Check"
                                Width="100" Height="32"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- SECTION: Customize Important Links -->
            <StackPanel Margin="0,0,0,32">
                <Grid Margin="0,0,0,20">
                    <TextBlock Text="Important Links Configuration" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               FontFamily="{StaticResource AppFont}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    
                    <Button Command="{Binding Dashboard.AddLinkCommand}"
                            Style="{StaticResource FluentButton}"
                            Width="36" Height="30"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            ToolTip="Add New Link">
                        <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xF067;" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- Input cards container -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="14,14,14,2">
                    <StackPanel>
                        <!-- Dynamic list of links -->
                        <ItemsControl ItemsSource="{Binding Dashboard.ImportantLinks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Link Title" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="2,0,0,4" FontFamily="{StaticResource AppFont}"/>
                                            <TextBox Style="{StaticResource FluentTextBox}" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="8,4" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Link URL" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="2,0,0,4" FontFamily="{StaticResource AppFont}"/>
                                            <TextBox Style="{StaticResource FluentTextBox}" Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="8,4" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="4"
                                                VerticalAlignment="Bottom"
                                                Height="30" Width="32"
                                                Padding="0"
                                                Style="{StaticResource FluentButtonSecondary}"
                                                Command="{Binding DataContext.Dashboard.RemoveLinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Delete Link">
                                            <TextBlock FontFamily="{StaticResource SegoeMDL2}" Text="&#xF068;" FontSize="11" Foreground="#ff5252" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Placeholder when there are no links -->
                        <TextBlock Text="No links configured. Click the + button above to add an important link."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dashboard.ImportantLinks.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- SECTION: Storage Card -->
            <Border Style="{StaticResource ThreeDCardStyle}"
                    Padding="12,10"
                    Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Label row -->
                    <StackPanel Grid.Column="0" Grid.Row="0" VerticalAlignment="Center">
                        <TextBlock Text="LOCAL CACHE STORAGE"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="{Binding CacheUsedText}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,3,0,0"
                                   FontFamily="{StaticResource AppFont}"/>
                    </StackPanel>

                    <!-- Clean button -->
                    <Button Grid.Column="1" Grid.Row="0"
                            Style="{StaticResource FluentButton}"
                            Command="{Binding CleanLogsCommand}"
                            Content="Clean"
                            VerticalAlignment="Center"
                            Width="80" Height="30"/>

                    <!-- Progress bar spanning full width -->
                    <ProgressBar Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2"
                                 Style="{StaticResource FluentProgressBar}"
                                 Value="{Binding CacheProgress}"
                                 Maximum="100"/>
                </Grid>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
