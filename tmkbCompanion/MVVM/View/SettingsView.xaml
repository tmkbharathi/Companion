<UserControl x:Class="tmkbCompanion.MVVM.View.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:tmkbCompanion.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" FocusVisualStyle="{x:Null}">
        <StackPanel Margin="20,20,20,30" MaxWidth="800" HorizontalAlignment="Left">
            
            <!-- SECTION: General Settings -->
            <StackPanel Margin="0,0,0,32">
                <Grid Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                   Text="&#xE9E9;" 
                                   FontSize="24" 
                                   Foreground="{DynamicResource AccentBrush}" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="General Settings" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   FontFamily="{StaticResource AppFont}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Content="Edit Profile Setup"
                            Command="{Binding DataContext.ShowProfileSetupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource FluentButtonSecondary}"
                            Height="32"
                            Padding="12,0"
                            FontSize="12"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Card 1: Launch on Startup -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="8" Width="48" Height="48"/>
                        <TextBlock Grid.Column="0" FontFamily="{StaticResource SegoeMDL2}" Text="&#xF133;" FontSize="22" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Launch on Startup" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                            <TextBlock Text="Automatically open FlowTrack when you sign in" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Opacity="0.8" Margin="0,2,0,0" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>

                        <!-- Toggle -->
                        <CheckBox Grid.Column="2" Style="{StaticResource FluentToggleSwitch}" IsChecked="{Binding LaunchOnStartup}"/>
                    </Grid>
                </Border>

                <!-- Card 2: Show Notifications -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="8" Width="48" Height="48"/>
                        <TextBlock Grid.Column="0" FontFamily="{StaticResource SegoeMDL2}" Text="&#xEA8F;" FontSize="22" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Show Notifications" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                            <TextBlock Text="Receive alerts about system status and focus goals" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Opacity="0.8" Margin="0,2,0,0" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>

                        <!-- Toggle -->
                        <CheckBox Grid.Column="2" Style="{StaticResource FluentToggleSwitch}" IsChecked="{Binding ShowNotifications}"/>
                    </Grid>
                </Border>

                <!-- Card 3: Pet Companion -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="8" Width="48" Height="48"/>
                        <TextBlock Grid.Column="0" FontFamily="{StaticResource SegoeMDL2}" Text="&#xE11D;" FontSize="22" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Pet Companion" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                            <TextBlock Text="Show a cute interactive cat that reacts to your typing" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Opacity="0.8" Margin="0,2,0,0" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>

                        <!-- Toggle -->
                        <CheckBox Grid.Column="2" Style="{StaticResource FluentToggleSwitch}" IsChecked="{Binding IsPetEnabled}"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- SECTION: Appearance -->
            <StackPanel Margin="0,0,0,32">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                               Text="&#xE771;" 
                               FontSize="24" 
                               Foreground="{DynamicResource AccentBrush}" 
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Appearance" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               FontFamily="{StaticResource AppFont}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Card 1: Dark Mode (Disabled) -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10"
                        Margin="0,0,0,12"
                        IsEnabled="False"
                        Opacity="0.5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="8" Width="48" Height="48"/>
                        <TextBlock Grid.Column="0" FontFamily="{StaticResource SegoeMDL2}" Text="&#xE708;" FontSize="22" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Dark Mode" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                                <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                                           Text="&#xE946;" 
                                           FontSize="14" 
                                           Foreground="{StaticResource TextMutedBrush}" 
                                           Opacity="0.8"
                                           VerticalAlignment="Center"
                                           Margin="8,2,0,0"
                                           Cursor="Help"
                                           ToolTipService.ShowOnDisabled="True"
                                           ToolTip="Later this feature will be enabled"/>
                            </StackPanel>
                            <TextBlock Text="Switch between light and dark visual themes" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Opacity="0.8" Margin="0,2,0,0" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>

                        <!-- Toggle -->
                        <CheckBox Grid.Column="2" Style="{StaticResource FluentToggleSwitch}" IsChecked="{Binding DarkMode}"/>
                    </Grid>
                </Border>

                <!-- Card 2: Accent Color -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" Opacity="0.1" CornerRadius="8" Width="48" Height="48"/>
                        <TextBlock Grid.Column="0" FontFamily="{StaticResource SegoeMDL2}" Text="&#xE790;" FontSize="22" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Details -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Accent Color" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" FontFamily="{StaticResource AppFont}"/>
                            <TextBlock Text="Customize the primary highlights of the interface" Foreground="{StaticResource TextMutedBrush}" FontSize="13" Opacity="0.8" Margin="0,2,0,0" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>

                        <!-- Colors Picker (4-Segment Capsule) -->
                        <Border Grid.Column="2" 
                                CornerRadius="16" 
                                ClipToBounds="True" 
                                Height="32" 
                                Width="140" 
                                BorderThickness="1" 
                                BorderBrush="{StaticResource BorderBrush}"
                                VerticalAlignment="Center">
                            <UniformGrid Columns="4">
                                <!-- Blue Accent -->
                                <Border Background="#5b8cff" Cursor="Hand" ToolTip="Accent Blue">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SetAccentColorCommand}" CommandParameter="#5b8cff"/>
                                    </Border.InputBindings>
                                </Border>
                                <!-- Red Accent -->
                                <Border Background="#ff5252" Cursor="Hand" ToolTip="Accent Red">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SetAccentColorCommand}" CommandParameter="#ff5252"/>
                                    </Border.InputBindings>
                                </Border>
                                <!-- Orange/Yellow Accent -->
                                <Border Background="#ffb874" Cursor="Hand" ToolTip="Accent Yellow">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SetAccentColorCommand}" CommandParameter="#ffb874"/>
                                    </Border.InputBindings>
                                </Border>
                                <!-- Green Accent -->
                                <Border Background="#10b981" Cursor="Hand" ToolTip="Accent Green">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding SetAccentColorCommand}" CommandParameter="#10b981"/>
                                    </Border.InputBindings>
                                </Border>
                            </UniformGrid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- SECTION: Customize Important Links -->
            <StackPanel Margin="0,0,0,32">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock FontFamily="{StaticResource SegoeMDL2}" 
                               Text="&#xE71B;" 
                               FontSize="24" 
                               Foreground="{DynamicResource AccentBrush}" 
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Important Links Configuration" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               FontFamily="{StaticResource AppFont}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Input cards container -->
                <Border Style="{StaticResource ThreeDCardStyle}" 
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Row 0: Link 1 -->
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Link 1 Title" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,2" FontFamily="{StaticResource AppFont}"/>
                            <TextBox Style="{StaticResource FluentTextBox}" Text="{Binding Dashboard.Link1Title, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="8,4" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Link 1 URL" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,2" FontFamily="{StaticResource AppFont}"/>
                            <TextBox Style="{StaticResource FluentTextBox}" Text="{Binding Dashboard.Link1Url, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="8,4" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- Row 2: Link 2 -->
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Link 2 Title" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,2" FontFamily="{StaticResource AppFont}"/>
                            <TextBox Style="{StaticResource FluentTextBox}" Text="{Binding Dashboard.Link2Title, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="8,4" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Link 2 URL" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,2" FontFamily="{StaticResource AppFont}"/>
                            <TextBox Style="{StaticResource FluentTextBox}" Text="{Binding Dashboard.Link2Url, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="8,4" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- Row 4: Link 3 -->
                        <StackPanel Grid.Row="4" Grid.Column="0">
                            <TextBlock Text="Link 3 Title" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,2" FontFamily="{StaticResource AppFont}"/>
                            <TextBox Style="{StaticResource FluentTextBox}" Text="{Binding Dashboard.Link3Title, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="8,4" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="2">
                            <TextBlock Text="Link 3 URL" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,2" FontFamily="{StaticResource AppFont}"/>
                            <TextBox Style="{StaticResource FluentTextBox}" Text="{Binding Dashboard.Link3Url, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="8,4" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- Row 6: Link 4 -->
                        <StackPanel Grid.Row="6" Grid.Column="0">
                            <TextBlock Text="Link 4 Title" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,2" FontFamily="{StaticResource AppFont}"/>
                            <TextBox Style="{StaticResource FluentTextBox}" Text="{Binding Dashboard.Link4Title, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="8,4" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="6" Grid.Column="2">
                            <TextBlock Text="Link 4 URL" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,2" FontFamily="{StaticResource AppFont}"/>
                            <TextBox Style="{StaticResource FluentTextBox}" Text="{Binding Dashboard.Link4Url, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="8,4" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- SECTION: Storage Card -->
            <Border Style="{StaticResource ThreeDCardStyle}"
                    Padding="12,10"
                    Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Label row -->
                    <StackPanel Grid.Column="0" Grid.Row="0" VerticalAlignment="Center">
                        <TextBlock Text="LOCAL CACHE STORAGE"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   FontFamily="{StaticResource AppFont}"/>
                        <TextBlock Text="{Binding CacheUsedText}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,3,0,0"
                                   FontFamily="{StaticResource AppFont}"/>
                    </StackPanel>

                    <!-- Clean button -->
                    <Button Grid.Column="1" Grid.Row="0"
                            Style="{StaticResource FluentButton}"
                            Command="{Binding CleanLogsCommand}"
                            Content="Clean"
                            VerticalAlignment="Center"
                            Width="80" Height="30"/>

                    <!-- Progress bar spanning full width -->
                    <ProgressBar Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2"
                                 Style="{StaticResource FluentProgressBar}"
                                 Value="{Binding CacheProgress}"
                                 Maximum="100"/>
                </Grid>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
